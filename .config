# ==========================================================
# 1. 3865U & N100 架构与固件分区设置（内核16M，系统分区512M）
# ==========================================================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
CONFIG_TARGET_KERNEL_PARTSIZE=16
CONFIG_TARGET_ROOTFS_PARTSIZE=512

# ==========================================================
# 2. 基础 Luci 网页界面和中文语言包
# ==========================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# ==========================================================
# 3. Passwall 2 核心及依赖（支持 WS、TLS、XTLS，带防污染 DNS）
# ==========================================================
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Xray-core=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Sing-Box=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_ChinaDNS-NG=y

# ==========================================================
# 4. TurboACC 网络加速及中文包
# ==========================================================
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y

# ==========================================================
# 5. 必备的安全证书与网络组件（TLS 握手、订阅、TUN 模式必备）
# ==========================================================
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y

# ==========================================================
# 6. 3865U & N100 兼容网卡与 CPU 驱动（防止刷入 N100 后网口不亮）
# ==========================================================
CONFIG_PACKAGE_kmod-igc=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-r8169=y
CONFIG_PACKAGE_kmod-coretemp=y
CONFIG_PACKAGE_intel-microcode=y

# ==========================================================
# 7. 附加实用工具：网页端命令行终端（选装，极力推荐）
# ==========================================================
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
# ==========================================================
# 8. ESXi 虚拟机专属优化（虚拟网卡驱动与关机助手）
# ==========================================================
CONFIG_PACKAGE_kmod-vmxnet3=y
CONFIG_PACKAGE_open-vm-tools=y
